@StudyDotnet.Api_HostAddress = http://localhost:5057

GET {{StudyDotnet.Api_HostAddress}}/
Accept: application/json

###

GET {{StudyDotnet.Api_HostAddress}}/api/v1/companies
Accept: application/json
X-Api-Key: study-key
X-Tenant: demo

###

GET {{StudyDotnet.Api_HostAddress}}/api/v1/companies/count
Accept: application/json
X-Api-Key: study-key
X-Tenant: lab

###

GET {{StudyDotnet.Api_HostAddress}}/api/v1/devices?keyword=hik&supplier=HIKvision&page=1&pageSize=10
Accept: application/json
X-Api-Key: study-key
X-Tenant: demo

###

POST {{StudyDotnet.Api_HostAddress}}/api/v1/devices/search
Content-Type: application/json
X-Api-Key: study-key
X-Tenant: demo

{
  "keyword": "hik",
  "supplier": "HIKvision",
  "page": 1,
  "pageSize": 10
}

###

POST {{StudyDotnet.Api_HostAddress}}/api/v2/auth/login
Content-Type: application/json

{
  "userName": "admin",
  "password": "study"
}

###

@DemoToken = dXNlcj1hZG1pbjt0ZW5hbnQ9ZGVtbw==

GET {{StudyDotnet.Api_HostAddress}}/api/v1/profile/me
Accept: application/json
X-Api-Key: study-key
Authorization: Bearer {{DemoToken}}
